# ZipIt Database Configuration
# Copy to .env and modify as needed

# Database Configuration
DATABASE_URL=postgresql://zipit_user:zipit_pass@localhost:5432/zipit_db

# For development (SQLite)
# DATABASE_URL=sqlite:///./data/zipit.db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=zipit_secret_key_change_in_production
JWT_SECRET_KEY=jwt_secret_key_change_in_production

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Application Settings
DEBUG=False
ENVIRONMENT=production
DOMAIN=zipit.com